# 后台管理配置
# 修改这个路径，让后台更难被发现
VITE_ADMIN_PATH=/your-secret-admin-path

# 管理员账号（生产环境请使用强密码）
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=your-strong-password-here

# JWT密钥（请生成一个随机字符串）
VITE_JWT_SECRET=your-random-jwt-secret-key

# 是否启用验证码
VITE_ENABLE_CAPTCHA=true

# 登录失败次数限制
VITE_MAX_LOGIN_ATTEMPTS=5

# 登录锁定时间（分钟）
VITE_LOCKOUT_DURATION=30
